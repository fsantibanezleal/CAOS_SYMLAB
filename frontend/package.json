  "type": "module",
  "description": "SymLab SPA: symbolic regression across the full method ladder, presenting a Pareto front of candidate laws as readable equations and interactive expression trees, replayed from committed artifacts with a live in-browser search lane.",
  "scripts": {
    "predev": "node copy-data.mjs",
    "dev": "vite",
