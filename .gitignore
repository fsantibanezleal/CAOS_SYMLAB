# Minimal-but-complete ignore for an instantiated product repo (ADR-0057).
# This ships WITH the template so every product inherits it from day 1.

# --- Python virtualenvs (ANY name, ANY depth) — NEVER committed; recreate via scripts/setup ---
.venv/
.venv*
**/.venv*
venv/
**/venv/

# --- Python caches / build ---
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.ruff_cache/
.mypy_cache/
build/
dist/

# --- Node / web ---
node_modules/
frontend/dist/
frontend/.vite/
# build-time overlay generated by frontend/copy-data.mjs (canonical copies live in data/derived + manifests)
frontend/public/data/
frontend/public/manifests/
frontend/public/pyodide/
*.tsbuildinfo

# --- Secrets / env (public repo — only .env.example is committed) ---
.env
.env.*
!.env.example

# --- Raw / heavy data — commit ONLY the compact derived artifacts under data/derived/ ---
data/raw/
*.parquet
*.h5
*.hdf5
*.nc
*.mat
*.npy
# large trained models stay local/LFS; commit small ONNX explicitly with `git add -f` if needed
models/*.pt
models/*.pth
*.dll
*.so
*.dylib

# --- OS / logs ---
.DS_Store
Thumbs.db
*.log
